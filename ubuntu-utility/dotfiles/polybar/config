[bar/main]
monitor = ${env:MONITOR:}
width = 100%
height = 30
offset-x = 0
offset-y = 0
radius = 0
bottom = true
line-size = 3
line-color = #282828

background = #282828
foreground = #d4be98

border-size = 0
border-color = #282828

padding-left = 0
padding-right = 2
module-padding-left = 1
module-padding-right = 1

font-0 = "monospace:size=11"
font-1 = "Font Awesome 6 Free:style=Solid:pixelsize=10"
font-2 = "Font Awesome 6 Brands:style=Solid:pixelsize=10"

modules-left = i3
modules-center = 
modules-right = volume battery date

tray-position = right
tray-padding = 2
tray-background = #282828

cursor-click = pointer
cursor-scroll = ns-resize

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
label-mode = %mode%
label-mode-padding = 2
label-mode-foreground = #000000
label-mode-background = #d4be98

label-focused = %index%
label-focused-foreground = #282828
label-focused-background = #7daea3
label-focused-padding = 2

label-unfocused = %index%
label-unfocused-foreground = #d4be98
label-unfocused-background = #282828
label-unfocused-padding = 2

label-visible = %index%
label-visible-foreground = #d4be98
label-visible-background = #282828
label-visible-padding = 2

label-urgent = %index%
label-urgent-foreground = #282828
label-urgent-background = #ea6962
label-urgent-padding = 2

[module/volume]
type = internal/volume
format-volume = <ramp-volume> <label-volume>
label-volume = %percentage%%
label-volume-foreground = #d4be98

format-muted = <label-muted>
label-muted = 婢 muted
label-muted-foreground = #504945

ramp-volume-0 = 奄
ramp-volume-1 = 奔
ramp-volume-2 = 奔

[module/battery]
type = internal/battery
full-at = 100
battery = BAT0
adapter = ADP1
poll-interval = 5

format-charging = <ramp-capacity> <label-charging>
label-charging = %percentage%%

format-discharging = <ramp-capacity> <label-discharging>
label-discharging = %percentage%%

format-full = <ramp-capacity> <label-full>
label-full = 100%%

format-prefix = " "
format-prefix-foreground = #d4be98
ramp-capacity-0 = 漆
ramp-capacity-1 = 谊
ramp-capacity-2 = 谊

label-full-foreground = #a9b665

[module/date]
type = internal/date
interval = 1
date = %Y-%m-%d%
time = %H:%M
format = <label>
format-padding = 2
label = %date%  %time%
label-foreground = #d4be98
