{
  "$schema": "https://opencode.ai/tui.json",

  "theme": "gruvbox",

  "mouse": true,

  "scroll_speed": 3,

  "scroll_acceleration": {
    "enabled": true
  },

  "diff_style": "auto",

  "attention": {
    "enabled": true,
    "notifications": true,
    "sound": false
  },

  "keybinds": {
    "command_list": "ctrl+p"
  }
}
